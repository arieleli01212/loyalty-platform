DATABASE_URL=sqlite+aiosqlite:///./loyalty.db
SECRET_KEY=changeme-use-a-real-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
WALLET_PROVIDER=stub
STAMP_THROTTLE_MINUTES=2
BASE_URL=http://localhost:8000
# Comma-separated list of allowed frontend origins (JSON array syntax for pydantic)
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000"]

# Email / OTP settings
# Leave RESEND_API_KEY empty to use the ConsoleEmailProvider (prints codes to stdout — great for local dev)
RESEND_API_KEY=
# The "from" address for OTP emails. Resend allows onboarding@resend.dev on the free tier.
EMAIL_FROM=onboarding@resend.dev
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Google OAuth
# Get a client ID from https://console.cloud.google.com/apis/credentials
# Leave empty to hide the Google sign-in button on the enrollment page.
GOOGLE_CLIENT_ID=
